# --- Anthropic (required for JD parsing + ATS rationale) ---
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Core URLs (service-to-service inside docker compose) ---
WEB_PORT=3000
ORCHESTRATOR_PORT=4000
AUTH_PORT=4001
RESUME_PARSER_URL=http://resume-parser:8001
JD_PARSER_URL=http://jd-parser:8002
ATS_ENGINE_URL=http://ats-engine:8003
OPTIMIZER_URL=http://ai-optimizer:8004

# Public URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Postgres ---
POSTGRES_USER=resumeai
POSTGRES_PASSWORD=resumeai_dev
POSTGRES_DB=resumeai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://resumeai:resumeai_dev@postgres:5432/resumeai?schema=public

# --- Mongo ---
MONGO_URL=mongodb://mongo:27017/resumeai

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3 compatible) ---
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=resumeai
S3_SECRET_KEY=resumeai_dev_secret
S3_BUCKET_RESUMES=resumes-raw
S3_BUCKET_JDS=jds-raw

# --- Auth ---
JWT_SECRET=dev-only-replace-in-prod-please-please
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# --- LLM model defaults ---
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
