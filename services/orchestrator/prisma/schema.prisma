// Prisma schema — single source of truth for Postgres.
// Both `auth` and `orchestrator` services share this DB.
// Auth service queries users via raw SQL (pg) to avoid schema duplication.

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String   @unique
  passwordHash         String?  @map("password_hash")     // nullable: OAuth-only users have no password
  fullName             String?  @map("full_name")
  plan                 String   @default("free")
  mfaEnabled           Boolean  @default(false) @map("mfa_enabled")
  mfaSecretEnc         String?  @map("mfa_secret_enc")    // base32-encoded TOTP secret
  mfaBackupCodesHash   Json?    @map("mfa_backup_codes_hash") // string[] of argon2 hashes
  createdAt            DateTime @default(now()) @map("created_at")
  deletedAt            DateTime? @map("deleted_at")

  resumes         Resume[]
  jobDescriptions JobDescription[]
  applications    Application[]
  oauthIdentities OAuthIdentity[]

  @@map("users")
}

model OAuthIdentity {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String                                  // google | github | linkedin
  providerUserId  String    @map("provider_user_id")      // sub / id from provider
  email           String?                                 // email reported at link time
  accessTokenEnc  String?   @map("access_token_enc")
  refreshTokenEnc String?   @map("refresh_token_enc")
  expiresAt       DateTime? @map("expires_at")
  linkedAt        DateTime  @default(now()) @map("linked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_identities")
  @@unique([provider, providerUserId])
  @@index([userId])
}

model Resume {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  sourceType      String   @map("source_type") // pdf | docx | latex
  s3Key           String   @map("s3_key")
  mongoDocId      String   @map("mongo_doc_id")
  currentVersionId String? @map("current_version_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  @@map("resumes")
  @@index([userId])
}

model ResumeVersion {
  id              String   @id @default(uuid()) @db.Uuid
  resumeId        String   @map("resume_id") @db.Uuid
  parentVersionId String?  @map("parent_version_id") @db.Uuid
  label           String?
  mongoDocId      String   @map("mongo_doc_id")
  s3PdfKey        String?  @map("s3_pdf_key")
  s3LatexKey      String?  @map("s3_latex_key")
  createdBy       String   @default("user") @map("created_by") // user | ai
  createdAt       DateTime @default(now()) @map("created_at")

  resume    Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  scores    AtsScore[]
  applications Application[]

  @@map("resume_versions")
  @@index([resumeId])
}

model JobDescription {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  sourceType  String   @map("source_type") // url | text | pdf | image
  sourceUrl   String?  @map("source_url")
  title       String?
  company     String?
  location    String?
  rawS3Key    String?  @map("raw_s3_key")
  parsedJson  Json     @map("parsed_json")
  contentHash String   @unique @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  scores AtsScore[]
  applications Application[]

  @@map("job_descriptions")
  @@index([userId])
}

model AtsScore {
  id                String   @id @default(uuid()) @db.Uuid
  resumeVersionId   String   @map("resume_version_id") @db.Uuid
  jdId              String   @map("jd_id") @db.Uuid
  overall           Float
  sectionScores     Json     @map("section_scores")
  matchedSkills     Json     @map("matched_skills")
  missingSkills     Json     @map("missing_skills")
  missingKeywords   Json     @map("missing_keywords")
  recruiterFit      Float    @map("recruiter_fit")
  rationale         String   @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  resumeVersion ResumeVersion  @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  jd            JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)

  @@map("ats_scores")
  @@index([jdId, overall(sort: Desc)])
}

model Application {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  jdId             String   @map("jd_id") @db.Uuid
  resumeVersionId  String   @map("resume_version_id") @db.Uuid
  platform         String
  externalId       String?  @map("external_id")
  status           String   // queued | in_progress | awaiting_user | submitted | failed
  mode             String   @default("review")
  attempts         Int      @default(0)
  lastError        String?  @map("last_error") @db.Text
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd            JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion  @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  @@map("applications")
  @@index([userId])
}

model UserPreference {
  userId              String   @id @map("user_id") @db.Uuid
  // form-fill profile
  firstName           String?  @map("first_name")
  lastName            String?  @map("last_name")
  phone               String?
  city                String?
  countryCode         String?  @map("country_code")
  workAuth            String?  @map("work_auth")
  needsSponsorship    Boolean? @map("needs_sponsorship")
  linkedinUrl         String?  @map("linkedin_url")
  githubUrl           String?  @map("github_url")
  portfolioUrl        String?  @map("portfolio_url")
  // auto-apply controls
  autoApplyEnabled    Boolean  @default(false) @map("auto_apply_enabled")
  defaultMode         String   @default("review") @map("default_mode") // review | auto
  minAtsScore         Float    @default(80) @map("min_ats_score")
  dailyApplyCap       Int      @default(5) @map("daily_apply_cap")
  // free-text screening Q&A
  questionBank        Json?    @map("question_bank")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model ApplyEvent {
  id            BigInt   @id @default(autoincrement())
  applicationId String   @map("application_id") @db.Uuid
  step          String                                  // e.g. "open_page", "fill_form", "screenshot", "awaiting_user", "submitted"
  ok            Boolean  @default(true)
  message       String?  @db.Text
  screenshotS3  String?  @map("screenshot_s3")
  meta          Json?
  at            DateTime @default(now())

  @@map("apply_events")
  @@index([applicationId, at])
}

// ----- Profile system (Phase 3.5) ----------------------------------------

model Profile {
  userId           String   @id @map("user_id") @db.Uuid
  fullName         String?  @map("full_name")
  phone            String?
  currentLocation  String?  @map("current_location")
  linkedinUrl      String?  @map("linkedin_url")
  githubUrl        String?  @map("github_url")
  portfolioUrl     String?  @map("portfolio_url")
  jobTitle         String?  @map("job_title")
  summary          String?
  languages        Json     @default("[]")  // string[]
  achievements     String?
  primaryResumeId  String?  @map("primary_resume_id") @db.Uuid
  completionPct    Int      @default(0) @map("completion_pct")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("profiles")
}

model ProfileExperience {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  company          String
  role             String
  startDate        String?  @map("start_date")
  endDate          String?  @map("end_date")
  responsibilities String?  @db.Text
  techStack        Json     @default("[]") @map("tech_stack")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("profile_experiences")
  @@index([userId, sortOrder])
}

model ProfileEducation {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  college     String
  degree      String?
  branch      String?
  startYear   String?  @map("start_year")
  endYear     String?  @map("end_year")
  gpa         String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("profile_education")
  @@index([userId, sortOrder])
}

model ProfileProject {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?  @db.Text
  techStack   Json     @default("[]") @map("tech_stack")
  githubUrl   String?  @map("github_url")
  liveUrl     String?  @map("live_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("profile_projects")
  @@index([userId, sortOrder])
}

model ProfileSkill {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("profile_skills")
  @@unique([userId, name])
}

model ProfileCertification {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  name          String
  issuer        String?
  issuedDate    String?  @map("issued_date")
  credentialUrl String?  @map("credential_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("profile_certifications")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  userId       String?  @map("user_id") @db.Uuid
  actor        String?
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  ip           String?
  ua           String?
  meta         Json?
  at           DateTime @default(now())

  @@map("audit_log")
  @@index([userId, at(sort: Desc)])
}
